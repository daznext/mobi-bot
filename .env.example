TELEGRAM_BOT_TOKEN=123456:replace-me

# Calibre CLI. Leave empty if ebook-convert is available in PATH.
EBOOK_CONVERT_BIN=ebook-convert

# SQLite and generated MOBI files.
BOT_DB_PATH=./data/bot.sqlite3
BOT_OUTPUT_DIR=./data/output

# SMTP account used by the bot to send files to Kindle.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=bot@example.com
SMTP_PASSWORD=replace-me
SMTP_FROM=bot@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

